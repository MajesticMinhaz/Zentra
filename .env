# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=dummy-secret-key-for-local-testing-only-change-in-prod
DJANGO_SETTINGS_MODULE=zentra.settings.dev
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://127.0.0.1:8080

# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=zentra
DB_USER=zentra
DB_PASSWORD=zentra
DB_HOST=db
DB_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── PGADMIN ────────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@zentra.dev
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT_EXPOSED=5050


# ─── Email (console backend — prints emails to docker logs, no SMTP needed) ───
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@localhost

# ─── Company / Branding ───────────────────────────────────────────────────────
COMPANY_NAME=Zentra Local
COMPANY_LOGO=
INVOICE_NUMBER_PREFIX=INV
QUOTE_NUMBER_PREFIX=QUO

# ─── Stripe (disabled locally) ────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_dummy
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy
