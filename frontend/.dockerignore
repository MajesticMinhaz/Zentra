# =============================================================================
# .dockerignore  —  Frontend (Node/Vite) build context
# =============================================================================

# ── Node runtime artefacts ────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ── Vite build output (rebuilt inside the image) ─────────────────────────────
dist/
.vite/
build/

# ── Test artefacts ────────────────────────────────────────────────────────────
coverage/

# ── Environment files ─────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Version control ───────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── IDE / editor files ────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker meta-files ─────────────────────────────────────────────────────────
Dockerfile
.dockerignore

# ── Documentation ─────────────────────────────────────────────────────────────
README.md
